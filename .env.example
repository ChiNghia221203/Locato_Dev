PORT=3000

# --- Storage (R2 chính — đổi env để migrate sang s3 | minio) ---
STORAGE_PROVIDER=r2

# Bắt buộc với r2/minio
# R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# MinIO local: http://localhost:9000
STORAGE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

STORAGE_REGION=auto
STORAGE_BUCKET=your-bucket
STORAGE_ACCESS_KEY_ID=your-access-key
STORAGE_SECRET_ACCESS_KEY=your-secret
STORAGE_PUBLIC_BASE_URL=
STORAGE_DEFAULT_PUBLIC=false
# true = path-style (thường dùng MinIO). false = virtual-hosted (AWS S3, R2). Mặc định: minio=true, còn lại=false
# STORAGE_FORCE_PATH_STYLE=false

# --- Supabase PostgreSQL (Prisma) ---
# App runtime: connection pooler (port 6543) — Supabase Dashboard → Database → Connection string → Transaction pooler
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# prisma migrate: direct connection (port 5432) — Session mode / Direct connection
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"
