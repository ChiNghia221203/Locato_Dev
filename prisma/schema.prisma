generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model FileAsset {
  id        String   @id @default(cuid())
  key       String
  bucket    String
  url       String?
  fileName  String
  mimeType  String
  size      Int
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bucket, key])
  @@map("file_assets")
}
